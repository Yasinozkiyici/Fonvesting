# Kopyala: cp .env.local.example .env.local — gerçek değerleri doldur (git’e ekleme).
# Uygulama çalışırken pooler URI kullanın.
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"

# Migration için doğrudan bağlantı.
DIRECT_URL="postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require"

NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY="your_publishable_key"
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
CRON_SECRET="change-me-for-local-sync-tests"
SOURCE_REFRESH_WORKER_WEBHOOK_URL=""
SOURCE_REFRESH_WORKER_TOKEN=""
