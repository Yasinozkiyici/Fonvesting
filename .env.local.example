# ÖNEMLİ: Bu repo SQLite şeması kullanır. `.env.local` içine Supabase/Postgres URL koyarsanız
# Prisma "URL must start with file:" hatası verir — arayüz yüklenir ama API'ler boş/ hata döner.
DATABASE_URL="file:./dev.db"
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
CRON_SECRET="change-me-for-local-sync-tests"
