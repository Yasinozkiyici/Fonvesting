  parseStatus   RawPayloadParseStatus @default(PENDING) @map("parse_status")
  parseError    String?               @map("parse_error")
  createdAt     DateTime              @default(now()) @map("created_at")
  @@index([source, fetchedAt(sort: Desc)])
  @@index([checksum])
  @@index([effectiveDate])
  @@map("raw_portfolio_breakdowns_payloads")
}

/** Günlük fon bütünlük / eksiklik skoru (serving öncesi denetim). */
model FundHealthDaily {
  id                String   @id @default(cuid())
  fundId            String   @map("fund_id")
  date              DateTime
  completenessScore Float?   @map("completeness_score")
  missingFields     Json?    @map("missing_fields")
  diagnostics       Json?
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  fund              Fund     @relation(fields: [fundId], references: [id], onDelete: Cascade)
  @@unique([fundId, date])
  @@index([date(sort: Desc)])
  @@map("fund_health_daily")
}

/**
 * Kanonik keşif teması: rebuild/backfill ile doldurulur; runtime’da isim token’ı tahmini yerine bu tablo.
 * themeId: FUND_THEMES.id ile uyumlu string (örn. green_energy).
 */
model FundThemeTag {
  fundCode  String   @map("fund_code")
  themeId   String   @map("theme_id")
  source    String   @default("inferred_v1")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@id([fundCode, themeId])
  @@index([themeId])
  @@index([fundCode])
  @@map("fund_theme_tag")
}

model ServingFundList {
  id           String   @id @default(cuid())
  buildId      String   @unique @map("build_id")
  snapshotAsOf DateTime @map("snapshot_as_of")
  status       String   @default("unknown")
  payload      Json
  meta         Json?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  @@index([snapshotAsOf(sort: Desc)])
  @@map("serving_fund_list")
}

model ServingFundDetail {
  id           String   @id @default(cuid())
  buildId      String   @map("build_id")
  fundCode     String   @map("fund_code")
  snapshotAsOf DateTime @map("snapshot_as_of")
  status       String   @default("unknown")
  payload      Json
  meta         Json?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  @@unique([buildId, fundCode])
  @@index([fundCode, snapshotAsOf(sort: Desc)])
  @@map("serving_fund_detail")
}

model ServingCompareInputs {
  id           String   @id @default(cuid())
  buildId      String   @unique @map("build_id")
  snapshotAsOf DateTime @map("snapshot_as_of")
  status       String   @default("unknown")
  payload      Json
  meta         Json?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  @@index([snapshotAsOf(sort: Desc)])
  @@map("serving_compare_inputs")
}

model ServingDiscoveryIndex {
  id           String   @id @default(cuid())
  buildId      String   @unique @map("build_id")
  snapshotAsOf DateTime @map("snapshot_as_of")
  status       String   @default("unknown")
  payload      Json
  meta         Json?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  @@index([snapshotAsOf(sort: Desc)])
  @@map("serving_discovery_index")
}

model ServingSystemStatus {
  id           String   @id @default(cuid())
  buildId      String   @unique @map("build_id")
  snapshotAsOf DateTime @map("snapshot_as_of")
  status       String   @default("unknown")
  payload      Json
  meta         Json?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  @@index([snapshotAsOf(sort: Desc)])
  @@map("serving_system_status")
}
