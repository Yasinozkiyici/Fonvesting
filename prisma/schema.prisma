generator client {
  provider = "prisma-client-js"
}

// Üretim (Vercel) ve yerel: PostgreSQL. Yerel için: docker compose up -d (bkz. docker-compose.yml).
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model FundCategory {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  color       String?
  funds       Fund[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([code])
}

model FundType {
  id          String   @id @default(cuid())
  code        Int      @unique
  name        String
  description String?
  funds       Fund[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Fund {
  id             String   @id @default(cuid())
  code           String   @unique
  name           String
  shortName      String?
  description    String?
  logoUrl        String?
  categoryId     String?
  category       FundCategory? @relation(fields: [categoryId], references: [id])
  fundTypeId     String?
  fundType       FundType? @relation(fields: [fundTypeId], references: [id])
  portfolioSize  Float    @default(0)
  investorCount  Int      @default(0)
  shareCount     Float    @default(0)
  lastPrice      Float    @default(0)
  previousPrice  Float    @default(0)
  dailyReturn    Float    @default(0)
  weeklyReturn   Float    @default(0)
  monthlyReturn  Float    @default(0)
  yearlyReturn   Float    @default(0)
  isActive       Boolean  @default(true)
  lastUpdatedAt  DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  priceHistory     FundPriceHistory[]
  dailySnapshots   FundDailySnapshot[]
  derivedMetrics   FundDerivedMetrics?
  healthDailyRows  FundHealthDaily[]
  watchlistItems   WatchlistItem[]
  @@index([isActive, portfolioSize(sort: Desc)])
  @@index([isActive, dailyReturn(sort: Desc)])
  @@index([portfolioSize(sort: Desc)])
  @@index([dailyReturn(sort: Desc)])
  @@index([categoryId])
}

/**
 * ~2 yıllık fiyat geçmişinden günlük job ile üretilen türetilmiş metrikler.
 * Liste/skor API’si ham FundPriceHistory taramadan buradan okur.
 */
model FundDerivedMetrics {
  fundId             String   @id
  fund               Fund     @relation(fields: [fundId], references: [id], onDelete: Cascade)
  categoryCode       String?
  fundTypeCode       Int?
  latestPrice        Float    @default(0)
  return1d           Float    @default(0)
  return7d           Float?
  return30d          Float?
  return90d          Float?
  return180d         Float?
  return1y           Float?
  return2y           Float?
  volatility1y       Float?
  volatility2y       Float?
  maxDrawdown1y      Float?
  maxDrawdown2y      Float?
  annualizedReturn1y Float    @default(0)
  sharpe1y           Float    @default(0)
  sortino1y          Float    @default(0)
  totalReturn2y      Float?
  investorCount      Int      @default(0)
  aum                Float    @default(0)
  historySessions    Int      @default(0)
  sparkline          Json
  computedAt         DateTime @default(now())
  updatedAt          DateTime @updatedAt
  @@index([categoryCode])
  @@index([categoryCode, return1y(sort: Desc)])
}

/** Günlük senkron sonrası /api/funds/scores yanıtı — anında okuma için (hesap sunucuda bir kez). */
model ScoresApiCache {
  cacheKey  String   @id
  payload   Json
  updatedAt DateTime @updatedAt
}

/** History backfill / incremental cursor: kapsanan tarih aralığını ve son koşumu izler. */
model HistorySyncState {
  key                 String   @id
  status              String   @default("IDLE")
  earliestHistoryDate DateTime?
  latestHistoryDate   DateTime?
  lastStartedAt       DateTime?
  lastCompletedAt     DateTime?
  details             Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model FundPriceHistory {
  id            String   @id @default(cuid())
  fundId        String
  date          DateTime
  price         Float
  dailyReturn   Float    @default(0)
  portfolioSize Float    @default(0)
  investorCount Int      @default(0)
  fund          Fund     @relation(fields: [fundId], references: [id], onDelete: Cascade)
  @@unique([fundId, date])
  @@index([date(sort: Desc)])
  @@index([fundId, date(sort: Desc)])
}

/** Günlük serving katmanı: ana sayfa ve skor cache bu tablodan okunur. */
model FundDailySnapshot {
  id                   String   @id @default(cuid())
  date                 DateTime
  fundId               String
  code                 String
  name                 String
  shortName            String?
  logoUrl              String?
  categoryCode         String?
  categoryName         String?
  fundTypeCode         Int?
  fundTypeName         String?
  riskLevel            String
  lastPrice            Float    @default(0)
  dailyReturn          Float    @default(0)
  monthlyReturn        Float    @default(0)
  yearlyReturn         Float    @default(0)
  portfolioSize        Float    @default(0)
  investorCount        Int      @default(0)
  alpha                Float    @default(0)
  sparkline            Json
  scores               Json
  metrics              Json
  finalScoreBest       Float    @default(0)
  finalScoreLowRisk    Float    @default(0)
  finalScoreHighReturn Float    @default(0)
  finalScoreStable     Float    @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  fund                 Fund     @relation(fields: [fundId], references: [id], onDelete: Cascade)
  @@unique([fundId, date])
  @@index([code, date(sort: Desc)])
  @@index([date(sort: Desc)])
  @@index([date(sort: Desc), categoryCode])
  @@index([date(sort: Desc), categoryCode, portfolioSize(sort: Desc)])
  @@index([date(sort: Desc), fundTypeCode, portfolioSize(sort: Desc)])
  @@index([date(sort: Desc), finalScoreBest(sort: Desc)])
  @@index([date(sort: Desc), finalScoreLowRisk(sort: Desc)])
  @@index([date(sort: Desc), finalScoreHighReturn(sort: Desc)])
  @@index([date(sort: Desc), finalScoreStable(sort: Desc)])
}

model MarketSnapshot {
  id                  String   @id @default(cuid())
  date                DateTime @unique
  totalFundCount      Int      @default(0)
  totalPortfolioSize  Float    @default(0)
  totalInvestorCount  Int      @default(0)
  avgDailyReturn      Float    @default(0)
  advancers           Int      @default(0)
  decliners           Int      @default(0)
  unchanged           Int      @default(0)
  usdTry              Float?
  eurTry              Float?
  createdAt           DateTime @default(now())
  @@index([date(sort: Desc)])
}

/**
 * Makro / benchmark serileri: BIST100, altın, politika faizi, TÜFE gibi
 * günlük/aylık gözlemler tek serving katmanında tutulur.
 */
model MacroSeries {
  id            String             @id @default(cuid())
  code          String             @unique
  name          String
  source        String
  sourceSymbol  String?
  frequency     String
  unit          String?
  currency      String?
  isActive      Boolean            @default(true)
  lastSyncedAt  DateTime?
  metadata      Json?
  observations  MacroObservation[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  @@index([source])
}

model MacroObservation {
  id         String      @id @default(cuid())
  seriesId   String
  date       DateTime
  value      Float
  open       Float?
  high       Float?
  low        Float?
  volume     Float?
  meta       Json?
  series     MacroSeries @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  @@unique([seriesId, date])
  @@index([date(sort: Desc)])
  @@index([seriesId, date(sort: Desc)])
}

model MacroSyncState {
  key                 String   @id
  status              String   @default("IDLE")
  earliestHistoryDate DateTime?
  latestHistoryDate   DateTime?
  lastStartedAt       DateTime?
  lastCompletedAt     DateTime?
  details             Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model SyncLog {
  id             String    @id @default(cuid())
  syncType       String
  status         String
  fundsUpdated   Int       @default(0)
  fundsCreated   Int       @default(0)
  errorMessage   String?
  startedAt      DateTime
  completedAt    DateTime?
  durationMs     Int?
  createdAt      DateTime  @default(now())
  @@index([createdAt(sort: Desc)])
  @@index([syncType, startedAt(sort: Desc)])
}

model CanonicalRawIngestRun {
  runId               String   @id @map("run_id")
  triggerType         String   @map("trigger_type")
  sourceEffectiveDate DateTime? @map("source_effective_date")
  fetchedRows         Int      @default(0) @map("fetched_rows")
  writtenRows         Int      @default(0) @map("written_rows")
  fetchSucceeded      Boolean  @default(false) @map("fetch_succeeded")
  writeSucceeded      Boolean  @default(false) @map("write_succeeded")
  isNoop              Boolean  @default(false) @map("is_noop")
  stageStatus         String   @map("stage_status")
  stageReason         String?  @map("stage_reason")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")
  @@index([sourceEffectiveDate(sort: Desc)])
  @@index([updatedAt(sort: Desc)])
  @@map("canonical_raw_ingest_runs")
}

model CanonicalSnapshotRun {
  runId       String   @id @map("run_id")
  snapshotDate DateTime? @map("snapshot_date")
  rowsWritten Int      @default(0) @map("rows_written")
  stageStatus String   @map("stage_status")
  stageReason String?  @map("stage_reason")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  @@index([snapshotDate(sort: Desc)])
  @@index([updatedAt(sort: Desc)])
  @@map("canonical_snapshot_runs")
}

model CanonicalServingPublishRun {
  runId        String   @id @map("run_id")
  buildId      String?  @map("build_id")
  snapshotDate DateTime? @map("snapshot_date")
  listRows     Int      @default(0) @map("list_rows")
  detailRows   Int      @default(0) @map("detail_rows")
  compareRows  Int      @default(0) @map("compare_rows")
  discoveryRows Int     @default(0) @map("discovery_rows")
  stageStatus  String   @map("stage_status")
  stageReason  String?  @map("stage_reason")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  @@index([snapshotDate(sort: Desc)])
  @@index([buildId])
  @@index([updatedAt(sort: Desc)])
  @@map("canonical_serving_publish_runs")
}

model CanonicalChartPublishRun {
  runId        String   @id @map("run_id")
  buildId      String?  @map("build_id")
  snapshotDate DateTime? @map("snapshot_date")
  chartRows    Int      @default(0) @map("chart_rows")
  stageStatus  String   @map("stage_status")
  stageReason  String?  @map("stage_reason")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  @@index([snapshotDate(sort: Desc)])
  @@index([buildId])
  @@index([updatedAt(sort: Desc)])
  @@map("canonical_chart_publish_runs")
}

model CanonicalComparisonPublishRun {
  runId          String   @id @map("run_id")
  buildId        String?  @map("build_id")
  snapshotDate   DateTime? @map("snapshot_date")
  comparisonRows Int      @default(0) @map("comparison_rows")
  stageStatus    String   @map("stage_status")
  stageReason    String?  @map("stage_reason")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  @@index([snapshotDate(sort: Desc)])
  @@index([buildId])
  @@index([updatedAt(sort: Desc)])
  @@map("canonical_comparison_publish_runs")
}

model User {
  id           String      @id @default(cuid())
  email        String      @unique
  name         String?
  passwordHash String?
  avatarUrl    String?
  isActive     Boolean     @default(true)
  isVerified   Boolean     @default(false)
  watchlists   Watchlist[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model Watchlist {
  id        String          @id @default(cuid())
  userId    String
  name      String          @default("Takip Listem")
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     WatchlistItem[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model WatchlistItem {
  id          String    @id @default(cuid())
  watchlistId String
  fundId      String
  alertPrice  Float?
  note        String?
  watchlist   Watchlist @relation(fields: [watchlistId], references: [id], onDelete: Cascade)
  fund        Fund      @relation(fields: [fundId], references: [id], onDelete: Cascade)
  addedAt     DateTime  @default(now())
  @@unique([watchlistId, fundId])
}

// --- Data platform v1 (parallel-run; legacy tablolar korunur) ---

enum RawPayloadParseStatus {
  PENDING
  OK
  FAILED
}

model RawMarketPayload {
  id            String                @id @default(cuid())
  source        String
  sourceKey     String                @map("source_key")
  fetchedAt     DateTime              @default(now()) @map("fetched_at")
  effectiveDate DateTime?             @map("effective_date")
  payload       Json
  checksum      String
  parseStatus   RawPayloadParseStatus @default(PENDING) @map("parse_status")
  parseError    String?               @map("parse_error")
  createdAt     DateTime              @default(now()) @map("created_at")
  @@index([source, fetchedAt(sort: Desc)])
  @@index([checksum])
  @@index([effectiveDate])
  @@map("raw_market_payloads")
}

model RawFundMetadataPayload {
  id            String                @id @default(cuid())
  source        String
  sourceKey     String                @map("source_key")
  fetchedAt     DateTime              @default(now()) @map("fetched_at")
  effectiveDate DateTime?             @map("effective_date")
  payload       Json
  checksum      String
  parseStatus   RawPayloadParseStatus @default(PENDING) @map("parse_status")
  parseError    String?               @map("parse_error")
  createdAt     DateTime              @default(now()) @map("created_at")
  @@index([source, fetchedAt(sort: Desc)])
  @@index([checksum])
  @@index([effectiveDate])
  @@map("raw_fund_metadata_payloads")
}

model RawInvestorCountsPayload {
