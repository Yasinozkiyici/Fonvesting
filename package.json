{
  "name": "bistmarketcap",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:3001": "next dev -p 3001",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "predeploy:check": "node scripts/predeploy-check.mjs",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:local:migrate": "DATABASE_URL=\"file:./dev.db\" prisma migrate deploy",
    "db:local:seed": "DATABASE_URL=\"file:./dev.db\" tsx prisma/seed.ts",
    "db:local:studio": "DATABASE_URL=\"file:./dev.db\" prisma studio",
    "sync:tefas": "tsx scripts/sync-tefas.ts",
    "setup:venv": "python3 -m venv scripts/.venv && scripts/.venv/bin/pip install -r scripts/requirements.txt",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "6.16.2",
    "dotenv": "^17.4.0",
    "lucide-react": "^0.544.0",
    "next": "14.2.15",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.10",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.15",
    "postcss": "^8.4.49",
    "prisma": "6.16.2",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.20.5",
    "typescript": "^5.6.3"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  }
}
