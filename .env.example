# Production / Vercel çalışma bağlantısı.
# Supabase Transaction pooler önerilir.
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"

# Migration için doğrudan bağlantı. `pnpm prod:migrate` bunu otomatik tercih eder.
DIRECT_URL="postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require"

# Public env
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY="your_publishable_key"
NEXT_PUBLIC_BASE_URL="https://your-domain.example"

# Vercel cron, /api/jobs/sync çağrısında bunu Bearer token olarak kullanır.
CRON_SECRET="güçlü-rastgele-dize-üret"
SOURCE_REFRESH_WORKER_WEBHOOK_URL=""
SOURCE_REFRESH_WORKER_TOKEN=""

# İsteğe bağlı: yerel PostgreSQL doğrulaması
# DATABASE_URL="postgresql://postgres:postgres@localhost:5433/fonvesting"
# DIRECT_URL="postgresql://postgres:postgres@localhost:5433/fonvesting"

# İsteğe bağlı: logo proxy ek hostlar
# FUND_LOGO_FETCH_EXTRA_HOSTS="cdn.ornek.com"
