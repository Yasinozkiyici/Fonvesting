# Database
# For local SQLite:
# DATABASE_URL="file:./prisma/dev.db"
#
# For production PostgreSQL (Supabase / AWS RDS):
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?schema=public"
DATABASE_URL=""

# Sync interval (hours)
YAHOO_SYNC_INTERVAL_HOURS="4"

# Required for secure cron job endpoint
CRON_SECRET=""
