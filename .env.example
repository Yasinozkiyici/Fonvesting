# Supabase (önerilen — Vercel/serverless): Transaction pooler, bölgeyi dashboard’daki host’tan alın.
# Örnek: postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"
#
# Yerel Docker (docker compose) — .env’de bunu kullanıyorsanız migrate + skor önbelleği aynı URL’ye gider:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5433/fonvesting"
# pnpm db:docker:up && pnpm db:docker:warm
# (Supabase .env ile çalışırken warm:scores Supabase’e gider; tablo yoksa önce bu URL ile migrate deploy edin.)
#
# Vercel + Supabase (özet): Uygulama çalışırken Transaction pooler URI kullanılabilir.
# Şema güncellemesi (migrate deploy) için bir kez doğrudan 5432 veya Session pooler gerekir.
# Skor tablosu (ScoresApiCache) yoksa bile API hesaplayıp listeler; tablo varsa + günlük warm ile yanıt çok hızlanır.
# Şema güncellemesi (migrate deploy) için doğrudan bağlantı — yalnızca yerel/CI:
# DATABASE_URL="postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require" pnpm exec prisma migrate deploy
#
# GitHub Actions günlük TEFAS: DATABASE_URL secret.
# db.*.supabase.co:5432 doğrudan bağlantı çoğu zaman IPv6’dır; GitHub Actions IPv4’tür → ulaşılamaz.
# Supabase → Connect → "Session pooler" URI kullanın (kullanıcı: postgres.PROJECT_REF).
# veya Connect → Transaction mode: db.*:6543 + ?pgbouncer=true&sslmode=require
# Ağ kısıtı (IP allowlist) varsa kapatın veya tümüne izin verin.

# Supabase (isteğe bağlı; istemci tarafı / gelecek özellikler)
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY="your_publishable_key"

YAHOO_SYNC_INTERVAL_HOURS="4"
CRON_SECRET="güçlü-rastgele-dize-üret"

# İsteğe bağlı: logo proxy ek hostlar
# FUND_LOGO_FETCH_EXTRA_HOSTS="cdn.ornek.com"
