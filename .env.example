# Prisma uygulama runtime (öncelik): transaction pooler. Tanımlıysa DATABASE_URL’den önce kullanılır.
# Prodlike / birçok ağ: db.*.supabase.co:5432 doğrudan erişilemez → pooler zorunlu sayılır.
POSTGRES_PRISMA_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"

# Fallback runtime (POSTGRES_PRISMA_URL yoksa). Yine pooler olmalı; migrate için ayrı DIRECT_URL kullanın.
# Runtime: transaction pooler (6543). Doğrudan db.*.supabase.co:5432 bazı yerel ağlarda erişilemez; prodlike için scripts/smoke-ui-prodlike.mjs varsayılan olarak NODE_OPTIONS içine --dns-result-order=ipv4first ekler (PRODLIKE_SUPABASE_IPV4_FIRST=0 ile kapatılır).
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"

# Migration / introspect için doğrudan Postgres. `pnpm prod:migrate` DIRECT_URL tercih eder; Prisma runtime bunu kullanmaz.
DIRECT_URL="postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require"

# Public env
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY="your_publishable_key"
NEXT_PUBLIC_BASE_URL="https://your-domain.example"

# İsteğe bağlı: prodlike sırasında doğrudan db.*.supabase.co DATABASE_URL için resolvePrismaDatasourceUrl fail-fast (varsayılan: yalnızca console.error).
# PRODLIKE_STRICT_SUPABASE_RUNTIME=1

# `pnpm data:release:gate` hedef URL (tercih: tek kaynak). Yoksa SMOKE_BASE_URL → RELEASE_PREVIEW_URL → NEXT_PUBLIC_BASE_URL sırası kullanılır.
# DATA_RELEASE_GATE_BASE_URL="https://your-preview.example"
# SMOKE_BASE_URL="http://127.0.0.1:3100"

# `daily_sync` SyncLog.errorMessage JSON üst sınırı (truth alanlarının kesilmemesi için).
# SYNC_LOG_JSON_MAX_LENGTH=65535

# Vercel cron, /api/jobs/sync çağrısında bunu Bearer token olarak kullanır.
CRON_SECRET="güçlü-rastgele-dize-üret"
# İsteğe bağlı: /api/cron/daily tek-uçuş guard TTL (ms). Varsayılan 480000 (8 dk). Sunucusuz maxDuration + tampon.
# CRON_DAILY_ACTIVE_RUN_TTL_MS=480000
SOURCE_REFRESH_WORKER_WEBHOOK_URL=""
SOURCE_REFRESH_WORKER_TOKEN=""
SERVING_REBUILD_WORKER_WEBHOOK_URL=""
SERVING_REBUILD_WORKER_TOKEN=""

# İsteğe bağlı: yerel PostgreSQL doğrulaması
# DATABASE_URL="postgresql://postgres:postgres@localhost:5433/fonvesting"
# DIRECT_URL="postgresql://postgres:postgres@localhost:5433/fonvesting"

# İsteğe bağlı: logo proxy ek hostlar
# FUND_LOGO_FETCH_EXTRA_HOSTS="cdn.ornek.com"
