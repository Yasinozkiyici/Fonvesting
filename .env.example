# PostgreSQL — Supabase: Project Settings → Database → Connection string (URI), şifreyi yerleştirin.
# sslmode=require kullanın. Yerel Docker alternatifi: docker compose + localhost:5433
DATABASE_URL="postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require"

# Supabase (isteğe bağlı; istemci tarafı / gelecek özellikler)
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY="your_publishable_key"

YAHOO_SYNC_INTERVAL_HOURS="4"
CRON_SECRET="güçlü-rastgele-dize-üret"

# İsteğe bağlı: logo proxy ek hostlar
# FUND_LOGO_FETCH_EXTRA_HOSTS="cdn.ornek.com"
